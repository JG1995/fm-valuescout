{
    "mcpServers": {
        "context7": {
            "command": "npx",
            "args": [
                "-y",
                "@upstash/context7-mcp"
            ],
            "env": {
                "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
            }
        },
        "jcodemunch": {
            "command": "uvx",
            "args": [
                "jcodemunch-mcp"
            ]
        },
		"tauri": {
      		"command": "npx",
      		"args": [
        		"-y",
        		"@hypothesi/tauri-mcp-server"
      		]
    	}
    }
}
